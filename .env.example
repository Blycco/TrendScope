# ============================================================
# TrendScope Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
APP_ENV=development
BASE_URL=
ALLOWED_ORIGINS=

# --- PostgreSQL ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Redis ---
REDIS_PASSWORD=
REDIS_URL=

# --- JWT (HS256) ---
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OAuth: Google ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth: Kakao ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- Payment ---
PAYMENT_WEBHOOK_SECRET=
PAYMENT_API_KEY=

# --- AI APIs ---
AI_GEMINI_API_KEY=
AI_OPENAI_API_KEY=

# --- Crawler APIs ---
YOUTUBE_API_KEY=
NITTER_BASE_URL=https://nitter.net

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=

# --- Image Tags (prod only) ---
API_IMAGE_TAG=latest
PROCESSOR_IMAGE_TAG=latest
CRAWLER_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
