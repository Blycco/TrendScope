# ============================================================
# TrendScope Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
APP_ENV=development
BASE_URL=
ALLOWED_ORIGINS=

# --- PostgreSQL ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Redis ---
REDIS_PASSWORD=
REDIS_URL=

# --- JWT (HS256) ---
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OAuth: Google ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth: Kakao ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- Payment ---
PAYMENT_PROVIDER=toss
PAYMENT_WEBHOOK_SECRET=

# --- AI APIs ---
AI_GEMINI_API_KEY=
AI_OPENAI_API_KEY=

# --- Crawler APIs ---
YOUTUBE_API_KEY=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_ALERT_EMAIL=

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=

# --- Image Tags (prod only) ---
API_IMAGE_TAG=latest
PROCESSOR_IMAGE_TAG=latest
CRAWLER_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# --- Logging ---
LOG_DIR=logs

# --- Load Testing (never use in production) ---
RATE_LIMIT_DISABLED=false   # true = 레이트 리밋 비활성화 (로드 테스트 전용)
QUOTA_DISABLED=false        # true = API 쿼타 비활성화 (로드 테스트 전용)
