      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "asyncpg_pool_size",
          "legendFormat": "pool size",
          "refId": "A"
        }
      ],
      "title": "DB Connection Pool Size",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
